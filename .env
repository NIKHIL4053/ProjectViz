# ──────────────────────────────────────────────────────────────────────────────
# .env — Environment Variables for Loan Dashboard
# ──────────────────────────────────────────────────────────────────────────────
#
# ! NEVER commit this file to git — add .env to your .gitignore
# ! NEVER share this file — it contains credentials
#
# * HOW TO USE:
# * 1. Copy this file to D:\Loan_Dashboard\.env
# * 2. Fill in values marked TODO
# * 3. Leave everything else as-is — config.py has sensible defaults
#
# ──────────────────────────────────────────────────────────────────────────────


# ── OLLAMA ────────────────────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434
CODER_MODEL=qwen2.5-coder:14b
FAST_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_RETRIES=2


# ── POWER BI — CREDENTIALS ────────────────────────────────────────────────────
# TODO: Fill these in — find them in Azure Portal and Power BI Service

# * Azure Portal → Azure Active Directory → Overview → Tenant ID
POWERBI_TENANT_ID=YOUR_TENANT_ID_HERE

# * Azure Portal → App Registrations → Your App → Application (client) ID
POWERBI_CLIENT_ID=YOUR_CLIENT_ID_HERE

# * Azure Portal → App Registrations → Your App → Certificates & secrets
POWERBI_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# * Power BI Service → Your Workspace URL → groups/{THIS_ID}/...
POWERBI_WORKSPACE_ID=YOUR_WORKSPACE_ID_HERE

# * Power BI Service → Your Dataset URL → datasets/{THIS_ID}/...
POWERBI_DATASET_ID=YOUR_DATASET_ID_HERE


# ── POWER BI — TABLE & QUERY SETTINGS ────────────────────────────────────────
# * These come from your fetcher code — only change if your dataset changes

# * Exact table name as it appears in Power BI Desktop (case sensitive)
# ! All Qwen-generated DAX will use 'Final Table'[column] syntax
POWERBI_TABLE_NAME=Final Table

# * Column used for RANKX pagination — must exist in 'Final Table'
RANK_INDEX_COLUMN=Rank_index

# * Rows fetched per API call — increase if you have fast network/Power BI Premium
POWERBI_BATCH_SIZE=10000

# * How much to increase batch size on retry if not enough rows returned
POWERBI_BATCH_INCREMENT=500

# * Minimum rows expected for a full raw data fetch
# ? Aggregated SUMMARIZECOLUMNS queries return far fewer rows — this is for full fetches only
POWERBI_MIN_ROWS=100000

# * Set to true during development — uses mock data, no Power BI calls made
# ! Change to false only when credentials above are filled in
USE_MOCK_DATA=true


# ── DATA STORAGE ──────────────────────────────────────────────────────────────

# * Parquet compression — snappy is fastest, gzip is smallest
PARQUET_COMPRESSION=snappy

# * How long (minutes) to keep session parquet files before auto-delete
TEMP_DATA_TTL_MINUTES=60


# ── CHROMADB ──────────────────────────────────────────────────────────────────

CHROMA_TOP_K=10


# ── MODEL CONTEXT ─────────────────────────────────────────────────────────────

SAMPLE_ROWS_FOR_MODEL=5
MAX_CONTEXT_TOKENS=6000


# ── CHARTS ────────────────────────────────────────────────────────────────────

CHART_DPI=150
MAX_CHART_CATEGORIES=15
SCATTER_SAMPLE_ROWS=600
PDF_PAGE_SIZE=A4
PDF_ORIENTATION=landscape


# ── STREAMLIT ─────────────────────────────────────────────────────────────────

MAX_SIDEBAR_SLICERS=5
MAX_CHAT_HISTORY=20


# ── LOGGING ───────────────────────────────────────────────────────────────────

LOG_LEVEL=DEBUG
LOG_ROTATION=10 MB
LOG_RETENTION=5