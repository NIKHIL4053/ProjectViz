# ──────────────────────────────────────────────────────────────────────────────
# .env — Environment Variables for Loan Dashboard
# ──────────────────────────────────────────────────────────────────────────────
#
# ! NEVER commit this file to git — add .env to your .gitignore
# ! NEVER share this file — it contains credentials
#
# * HOW TO USE:
# * 1. Copy this file to D:\Loan_Dashboard\.env
# * 2. Fill in values marked TODO
# * 3. Leave everything else as-is — config.py has sensible defaults
#
# ──────────────────────────────────────────────────────────────────────────────


# ── OLLAMA ────────────────────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434
CODER_MODEL=qwen2.5-coder:14b
FAST_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=600
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_RETRIES=2

# ── Lines to update in your .env ─────────────────────────────────────────────
# Find and change these two lines:
 
# Before:
# PG_TABLE_NAME=final_table
 
# After:
PG_TABLE_NAME=loan_dashboard
 
# Everything else stays the same.
# Your full PostgreSQL block should look like this:
 
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=LD
PG_USER=nik
PG_PASSWORD=kin
PG_SCHEMA=public
PG_TABLE_NAME=loan_dashboard
PG_MAX_ROWS=100000
USE_MOCK_DATA=false

# ── DATA STORAGE ──────────────────────────────────────────────────────────────

# * Parquet compression — snappy is fastest, gzip is smallest
PARQUET_COMPRESSION=snappy

# * How long (minutes) to keep session parquet files before auto-delete
TEMP_DATA_TTL_MINUTES=60


# ── CHROMADB ──────────────────────────────────────────────────────────────────

CHROMA_TOP_K=10


# ── MODEL CONTEXT ─────────────────────────────────────────────────────────────

SAMPLE_ROWS_FOR_MODEL=5
MAX_CONTEXT_TOKENS=6000


# ── CHARTS ────────────────────────────────────────────────────────────────────

CHART_DPI=150
MAX_CHART_CATEGORIES=15
SCATTER_SAMPLE_ROWS=600
PDF_PAGE_SIZE=A4
PDF_ORIENTATION=landscape


# ── STREAMLIT ─────────────────────────────────────────────────────────────────

MAX_SIDEBAR_SLICERS=5
MAX_CHAT_HISTORY=20


# ── LOGGING ───────────────────────────────────────────────────────────────────

LOG_LEVEL=DEBUG
LOG_ROTATION=10 MB
LOG_RETENTION=5