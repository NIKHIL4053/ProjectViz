# ──────────────────────────────────────────────────────────────────────────────
# .env — Environment Variables for Loan Dashboard
# ──────────────────────────────────────────────────────────────────────────────
#
# ! NEVER commit this file to git — add .env to your .gitignore
# ! NEVER share this file — it contains credentials and secrets
#
# * HOW TO USE:
# * 1. Copy this file to D:\Loan_Dashboard\.env
# * 2. Fill in the values marked with TODO
# * 3. Leave values you don't need as-is — config.py has sensible defaults
#
# ──────────────────────────────────────────────────────────────────────────────


# ── OLLAMA ────────────────────────────────────────────────────────────────────

# * URL where Ollama is running — default is fine unless you changed Ollama's port
OLLAMA_BASE_URL=http://localhost:11434

# * Model names — change if you want to use a different size variant
# ? Options for coder: qwen2.5-coder:7b | qwen2.5-coder:14b | qwen2.5-coder:32b
# ? Options for fast:  qwen2.5:3b | qwen2.5:7b | qwen2.5:14b
CODER_MODEL=qwen2.5-coder:14b
FAST_MODEL=qwen2.5:7b

# * How long to wait for a model response before timing out (seconds)
OLLAMA_TIMEOUT=120

# * Temperature — keep low for deterministic DAX and JSON output
# ? Range: 0.0 (fully deterministic) to 1.0 (creative/random)
OLLAMA_TEMPERATURE=0.1

# * How many times to retry a failed Ollama request
OLLAMA_MAX_RETRIES=2


# ── POWER BI ──────────────────────────────────────────────────────────────────
# TODO: Fill these in once Power BI fetcher code is found
# * How to find these values:
# *   TENANT_ID     → Azure Portal → Azure Active Directory → Overview → Tenant ID
# *   CLIENT_ID     → Azure Portal → App Registrations → Your App → Application (client) ID
# *   CLIENT_SECRET → Azure Portal → App Registrations → Your App → Certificates & secrets
# *   WORKSPACE_ID  → Power BI Service → Your Workspace URL → groups/{THIS_ID}/...
# *   DATASET_ID    → Power BI Service → Your Dataset URL → datasets/{THIS_ID}/...
# *   TABLE_NAME    → Power BI Desktop → Data view → Table name on left panel

POWERBI_TENANT_ID=YOUR_TENANT_ID_HERE
POWERBI_CLIENT_ID=YOUR_CLIENT_ID_HERE
POWERBI_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
POWERBI_WORKSPACE_ID=YOUR_WORKSPACE_ID_HERE
POWERBI_DATASET_ID=YOUR_DATASET_ID_HERE
POWERBI_TABLE_NAME=YOUR_TABLE_NAME_HERE

# * Set to true during development — uses mock data instead of real Power BI API
# ! Change to false only when Power BI credentials above are filled in
USE_MOCK_DATA=true


# ── CHROMADB ──────────────────────────────────────────────────────────────────

# * How many relevant chunks to fetch from ChromaDB per query
# ? Higher = more context for Qwen but larger prompt size
CHROMA_TOP_K=10


# ── DATA HANDLING ─────────────────────────────────────────────────────────────

# * Maximum Excel upload size in MB
MAX_UPLOAD_SIZE_MB=100

# * How many sample rows to send to Qwen for column analysis
SAMPLE_ROWS_FOR_MODEL=5

# * Max tokens to use for context injection into prompts
MAX_CONTEXT_TOKENS=6000

# * How long (minutes) to keep temp session data before auto-deleting
TEMP_DATA_TTL_MINUTES=60


# ── CHARTS ────────────────────────────────────────────────────────────────────

# * DPI for exported charts and PDF
CHART_DPI=150

# * Max x-axis categories before truncating
MAX_CHART_CATEGORIES=15

# * Max rows to use for scatter plots (prevents slowness with 89K rows)
SCATTER_SAMPLE_ROWS=600

# * PDF export settings
PDF_PAGE_SIZE=A4
PDF_ORIENTATION=landscape


# ── STREAMLIT ─────────────────────────────────────────────────────────────────

# * Max sidebar filter dropdowns to show at once
MAX_SIDEBAR_SLICERS=5

# * Max chat messages to keep in session memory
MAX_CHAT_HISTORY=20


# ── LOGGING ───────────────────────────────────────────────────────────────────

# * Console log level
# ? DEBUG during development, INFO in production
LOG_LEVEL=DEBUG

# * Log file rotation size
LOG_ROTATION=10 MB

# * Number of rotated log files to keep per log file
LOG_RETENTION=5